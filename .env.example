# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by: docker-compose.yml, platform/api/db.go, intelligence/etl_to_database.py
DB_HOST=localhost
DB_PORT=5432
DB_USER=api_user
DB_PASSWORD=api_password
DB_NAME=rocket_elevators

# ── Go API ────────────────────────────────────────────────────────────────────
# Used by: platform/api/main.go
# Port must be 8080 — 8081 is blocked by the company firewall
PORT=8080

# ── Flask dashboard ───────────────────────────────────────────────────────────
# Used by: platform/server.py
# Points to the Go API — change only if running the API on a different host/port
GO_API=http://localhost:8080

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Used by: intelligence/generate_explanations.py
# Default Ollama port — do not change unless you moved Ollama to a custom port
OLLAMA_URL=http://localhost:11434

# ── Docker container name ─────────────────────────────────────────────────────
# Used by: intelligence/generate_explanations.py
# Must match the container name shown by `docker ps` for the PostgreSQL service
DB_CTR=rocket-elevators-ops-dashboard-db-1

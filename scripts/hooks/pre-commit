#!/usr/bin/env bash
# Prevents accidental modification of source datasets in /data.
# /data is read-only — only prepare_data.py writes elevator_fleet.csv.

staged=$(git diff --cached --name-only)

if echo "$staged" | grep -q "^data/"; then
    echo ""
    echo "  COMMIT BLOCKED: /data is read-only."
    echo ""
    echo "  Staged files under /data:"
    echo "$staged" | grep "^data/" | sed 's/^/    /'
    echo ""
    echo "  Source datasets must never be modified in-place."
    echo "  To regenerate the unified dataset, run:"
    echo "    py -3 platform/prepare_data.py"
    echo ""
    exit 1
fi

exit 0
